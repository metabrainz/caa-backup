{{- with service "pgbouncer-slave"}}{{with index . 0 -}}
PG_CONN_STRING = 'postgresql://musicbrainz_ro@{{.Address}}:{{.Port}}/musicbrainz_db'
{{- end}}{{else -}}
{{- with service "pgbouncer-master"}}{{with index . 0 -}}
PG_CONN_STRING = 'postgresql://musicbrainz_ro@{{.Address}}:{{.Port}}/musicbrainz_db'
{{- end}}{{else -}}
PG_CONN_STRING = ""
{{- end}}{{end}}
